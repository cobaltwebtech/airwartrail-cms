---
import "@/styles/global.css";
import { DashboardFooter } from "@/components/DashboardFooter";
import { Toaster } from "@/components/ui/sonner";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Manage your video content with Bunny.net Stream",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Air War Trail</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      const getThemePreference = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      };
      const isDark = getThemePreference() === "dark";
      document.documentElement.classList[isDark ? "add" : "remove"]("dark");

      if (typeof localStorage !== "undefined") {
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
        });
        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }
    </script>
  </head>
  <body class="bg-background">
    <div class="w-full">
      <main class="flex min-h-dvh flex-col gap-4 p-4 md:gap-8 md:p-8">
        <slot />
      </main>
      <DashboardFooter client:visible />
    </div>
    <Toaster position="top-right" client:load />
  </body>
</html>
