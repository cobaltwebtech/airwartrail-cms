{
  "name": "airwartrail-dashboard",
  "type": "module",
  "version": "0.65.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "astro dev",
    "dev:remote": "astro build && pnpx wrangler dev --remote",
    "migrate:auth": "pnpx @better-auth/cli migrate --config src/lib/auth-server.ts",
    "format": "prettier . --write",
    "lint": "eslint .",
    "build": "astro build",
    "preview": "astro preview",
    "upforce": "pnpm up --latest --recursive '*'",
    "up:astro": "pnpx @astrojs/upgrade",
    "astro": "astro",
    "clean": "rimraf dist .astro node_modules pnpm-lock.yaml yarn.lock .yarn package-lock.json .wrangler"
  },
  "dependencies": {
    "@astrojs/cloudflare": "12.6.3",
    "@astrojs/react": "4.3.0",
    "@hookform/resolvers": "^5.2.1",
    "@libsql/client": "0.15.10",
    "@libsql/kysely-libsql": "0.4.1",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@tailwindcss/vite": "^4.1.11",
    "@types/better-sqlite3": "^7.6.13",
    "astro": "5.12.9",
    "better-auth": "1.3.4",
    "better-sqlite3": "^12.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "kysely": "^0.28.4",
    "lucide-react": "^0.539.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "tus-js-client": "^4.3.1",
    "zod": "^4.0.15"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.3.4",
    "@cloudflare/workers-types": "^4.20250807.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.32.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0",
    "wrangler": "^4.28.1"
  },
  "resolutions": {
    "kysely": "^0.28.2"
  }
}
