{
  "name": "airwartrail-dashboard",
  "type": "module",
  "version": "0.63.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "dev:remote": "astro build && npx wrangler dev --remote",
    "migrate:auth": "npx @better-auth/cli migrate --config src/lib/auth-server.ts",
    "format": "prettier . --write",
    "lint": "eslint .",
    "build": "astro build",
    "preview": "astro preview",
    "update": "pnpm up --latest --recursive '*'",
    "update:astro": "pnpm dlx @astrojs/upgrade",
    "astro": "astro",
    "clean": "rimraf dist .astro node_modules pnpm-lock.yaml yarn.lock .yarn package-lock.json .wrangler"
  },
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "@astrojs/cloudflare": "12.5.4",
    "@astrojs/react": "4.3.0",
    "@hookform/resolvers": "^5.1.1",
    "@libsql/client": "0.4.1",
    "@libsql/kysely-libsql": "0.4.1",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@tailwindcss/vite": "^4.1.10",
    "@types/better-sqlite3": "^7.6.13",
    "astro": "5.9.3",
    "better-auth": "1.2.9",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "kysely": "^0.28.2",
    "lucide-react": "^0.503.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.58.0",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.10",
    "tailwindcss-animate": "^1.0.7",
    "tus-js-client": "^4.3.1",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.2.9",
    "@cloudflare/workers-types": "^4.20250614.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/parser": "^8.34.0",
    "eslint": "^9.29.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "wrangler": "^4.20.0"
  },
  "resolutions": {
    "kysely": "^0.28.2"
  }
}
