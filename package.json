{
  "name": "airwartrail-dashboard",
  "type": "module",
  "version": "0.66.1",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "astro dev",
    "dev:remote": "astro build && pnpx wrangler dev --remote",
    "migrate:auth": "pnpx @better-auth/cli migrate --config src/lib/auth-server.ts",
    "format": "prettier . --write",
    "lint": "eslint .",
    "build": "astro build",
    "preview": "astro preview",
    "upforce": "pnpm up --latest --recursive '*'",
    "up:astro": "pnpx @astrojs/upgrade",
    "astro": "astro",
    "clean": "rimraf dist .astro node_modules pnpm-lock.yaml .wrangler"
  },
  "dependencies": {
    "@astrojs/cloudflare": "12.6.12",
    "@astrojs/react": "4.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "0.15.14",
    "@libsql/kysely-libsql": "0.4.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.1.17",
    "@types/better-sqlite3": "^7.6.13",
    "astro": "5.16.4",
    "better-auth": "1.3.8",
    "better-sqlite3": "^12.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "kysely": "^0.28.8",
    "lucide-react": "^0.542.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.68.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "tailwindcss-animate": "^1.0.7",
    "tus-js-client": "^4.3.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.5",
    "@cloudflare/workers-types": "^4.20251205.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "eslint-plugin-astro": "^1.5.0",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "wrangler": "^4.53.0"
  },
  "resolutions": {
    "kysely": "^0.28.5"
  }
}
